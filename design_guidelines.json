{
  "project_name": "ROSHKA STUDIO",
  "theme": "dark_premium",
  "design_philosophy": {
    "archetype": "JEWEL & LUXURY",
    "vibe": "Sophisticated, Mysterious, Elite, Digital Craftsmanship",
    "core_principle": "Black is the canvas, Gold is the light. Glass is the lens.",
    "anti_patterns": [
      "No generic 'Startups Blue'",
      "No flat solid grey backgrounds",
      "No 'Bootstrap' grid layouts - use asymmetry"
    ]
  },
  "typography": {
    "headings": {
      "font_family": "Playfair Display, serif",
      "weights": ["400", "600", "700"],
      "usage": "Hero titles, Section headers",
      "tracking": "tracking-tight"
    },
    "body": {
      "font_family": "Manrope, sans-serif",
      "weights": ["300", "400", "500"],
      "usage": "Paragraphs, UI elements, Buttons",
      "tracking": "tracking-normal"
    },
    "mono": {
      "font_family": "JetBrains Mono, monospace",
      "usage": "Decorative numbers, 'Code' snippets in design",
      "size": "text-xs"
    }
  },
  "colors": {
    "palette": {
      "background": "#050505",
      "surface": "#0A0A0A",
      "surface_highlight": "#151515",
      "primary": "#D4AF37",
      "primary_dim": "#B8860B",
      "text_primary": "#F5F5F5",
      "text_secondary": "#A3A3A3",
      "border_subtle": "rgba(255, 255, 255, 0.08)",
      "gold_gradient": "linear-gradient(135deg, #D4AF37 0%, #F6E27A 50%, #B8860B 100%)"
    },
    "tailwind_config_extension": {
      "colors": {
        "roshka-bg": "#050505",
        "roshka-gold": "#D4AF37",
        "roshka-gold-dim": "#B8860B",
        "roshka-surface": "#0A0A0A"
      },
      "backgroundImage": {
        "gold-gradient": "linear-gradient(135deg, #D4AF37 0%, #F6E27A 50%, #B8860B 100%)",
        "glass-gradient": "linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%)"
      }
    }
  },
  "visual_enhancers": {
    "glassmorphism": {
      "base": "backdrop-blur-xl bg-white/5 border border-white/10",
      "hover": "hover:bg-white/10 hover:border-roshka-gold/30 transition-all duration-500"
    },
    "shadows": {
      "glow": "0 0 40px -10px rgba(212, 175, 55, 0.15)",
      "neon": "0 0 10px rgba(212, 175, 55, 0.5)"
    },
    "borders": {
      "subtle": "border border-white/5",
      "highlight": "border-t border-white/10"
    }
  },
  "layout_strategies": {
    "container": "max-w-7xl mx-auto px-6 md:px-12",
    "section_spacing": "py-24 md:py-32",
    "grid_system": "Use 'Bento' grids. Avoid equal columns. Mix 2/3 + 1/3 splits."
  },
  "components": {
    "navbar": {
      "style": "Floating glass pill or full-width glass header",
      "features": [
        "Logo: ROSHKA (Serif, Gold)",
        "Desktop: Clean links + 'Start Project' Gold Button",
        "Mobile: Hamburger menu opening a full-screen blurred overlay"
      ]
    },
    "hero": {
      "style": "Cinematic, dark, immersive",
      "elements": [
        "Background: Abstract Gold Waves (Image)",
        "Headline: 'Crafting Digital Legacies' (Playfair Display, 5xl+)",
        "Subtext: 'A creative studio in Silver Spring, MD'",
        "CTA: 'View Work' (Outline) + 'Contact' (Solid Gold)"
      ]
    },
    "services": {
      "style": "Glass Cards with Gold Icons",
      "layout": "Grid of 3 or 4 cards. Hover effects mandatory (border glow)."
    },
    "portfolio": {
      "style": "Masonry / Asymmetrical Grid",
      "elements": "Large imagery, minimal text overlay on hover. Project names in Serif."
    },
    "process": {
      "style": "Vertical Timeline or Horizontal Scroll",
      "detail": "Connect steps with a faint gold line. Active step glows."
    },
    "contact": {
      "style": "Minimalist High-End Form",
      "elements": [
        "Input fields: Transparent bg, border-bottom only (or minimal glass inputs)",
        "Gold Submit Button",
        "Email: ogrisko54@gmail.com (Clickable)",
        "Location: Silver Spring, MD (Map optional)"
      ]
    }
  },
  "image_urls": {
    "hero_bg": "https://images.unsplash.com/photo-1762281310960-c141929e28eb?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NzF8MHwxfHNlYXJjaHwxfHxhYnN0cmFjdCUyMGJsYWNrJTIwYW5kJTIwZ29sZCUyMGdlb21ldHJpYyUyMHdhdmVzfGVufDB8fHx8MTc3MjU2MjgzOXww&ixlib=rb-4.1.0&q=85",
    "about_office": "https://images.unsplash.com/photo-1713346774461-f93209c40386?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NjZ8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBjcmVhdGl2ZSUyMG9mZmljZSUyMHN0dWRpbyUyMGRhcmslMjBpbnRlcmlvcnxlbnwwfHx8fDE3NzI1NjI4NDB8MA&ixlib=rb-4.1.0&q=85",
    "abstract_gold": "https://images.unsplash.com/photo-1769123012414-6c6b5c17ad45?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NzF8MHwxfHNlYXJjaHwyfHxhYnN0cmFjdCUyMGJsYWNrJTIwYW5kJTIwZ29sZCUyMGdlb21ldHJpYyUyMHdhdmVzfGVufDB8fHx8MTc3MjU2MjgzOXww&ixlib=rb-4.1.0&q=85"
  },
  "accessibility": {
    "contrast": "Ensure Gold text is readable on Black. Use lighter gold (#F6E27A) for text, darker (#D4AF37) for borders.",
    "interactive": "All buttons must have :focus-visible states."
  },
  "animation_guidelines": {
    "library": "framer-motion",
    "preferences": [
      "Smooth fade-ins (y: 20 -> 0, opacity: 0 -> 1)",
      "Stagger children for lists",
      "Parallax on background images"
    ]
  },
  "universal_guidelines": [
    "Don't make generic centered layouts.",
    "Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters.",
    "NEVER use AI assistant Emoji characters.",
    "Every interaction needs micro-animations.",
    "Use 2-3x more spacing than feels comfortable."
  ],
  "instructions_to_main_agent": "1. Install 'framer-motion', 'lucide-react'. 2. Update tailwind.config.js with the new colors and fonts. 3. Import fonts in index.css (Playfair Display, Manrope). 4. Build the pages using the defined components. 5. Ensure the Contact form works."
}